#!/bin/sh

# Generated CSS is loaded by the theme at runtime. Rebuild it whenever a staged
# change can affect the bundle, then require the regenerated files to be staged.
cd "$(git rev-parse --show-toplevel)" || exit 1

if git diff --cached --quiet -- \
	':(glob)styles/**/*.css' \
	':(exclude,glob)styles/dist/**' \
	package.json \
	pnpm-lock.yaml \
	scripts/fix-css-source-map-urls.mjs; then
	exit 0
fi

printf '%s\n' 'Rebuilding generated theme CSS...'
if ! pnpm compile:css; then
	printf '%s\n' 'Unable to rebuild generated theme CSS; commit stopped.' >&2
	exit 1
fi

if ! git diff --quiet -- styles/dist/*.min.css || git ls-files --others --exclude-standard -- styles/dist/*.min.css | grep -q .; then
	printf '%s\n' '' >&2
	printf '%s\n' 'Generated theme CSS is out of date.' >&2
	printf '%s\n' 'The pre-commit hook rebuilt the runtime CSS, but the generated files are not staged.' >&2
	printf '%s\n' 'Review the output, then run: git add styles/dist/*.min.css' >&2
	printf '%s\n' 'Commit again after staging the regenerated assets.' >&2
	git status --short -- styles/dist/*.min.css >&2
	exit 1
fi
